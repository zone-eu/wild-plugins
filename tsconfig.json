{
    "compilerOptions": {
        "target": "ES2020",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "allowJs": true,
        "checkJs": true,
        "noEmit": true,
        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
    },
    "include": [
        "index.js",
        "*.d.ts",
        "src/**/*.d.ts",
        "src/**/*.js"
    ]
}
